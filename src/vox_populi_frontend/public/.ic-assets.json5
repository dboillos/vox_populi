[
    {
        "match": "**/*",

        // En local, la policy "standard" añade una cabecera Permissions-Policy
        // con features no reconocidas por algunos navegadores, generando ruido en consola.
        // La desactivamos para evitar esos warnings durante desarrollo/pruebas.
        // Opciones: "hardened" | "standard" | "disabled".
        "security_policy": "disabled",

        // Uncomment to disable the warning about using the
        // standard security policy, if you understand the risk
        // "disable_security_policy_warning": true,

        // Uncomment to redirect all requests from .raw.icp0.io to .icp0.io
        // "allow_raw_access": false
    },
]
