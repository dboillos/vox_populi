[
    {
        "match": "**/*",
        "security_policy": "disabled"
    },
    {
        // index.html nunca debe cachearse: referencia JS/CSS con hash que cambia en cada release.
        // Sin esto, los navegadores sirven el index.html antiguo tras un deploy y obtienen 503
        // al intentar cargar bundles que ya no existen en el canister.
        "match": "index.html",
        "headers": {
            "Cache-Control": "no-store, no-cache, must-revalidate"
        }
    },
    {
        // Assets con hash en el nombre son inmutables: se cachean indefinidamente.
        "match": "assets/**",
        "headers": {
            "Cache-Control": "public, max-age=31536000, immutable"
        }
    }
]
